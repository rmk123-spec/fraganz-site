<!DOCTYPE html>
<html lang="pt-BR"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fraganz — Perfumes Importados</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,600;1,9..144,500&amp;family=Manrope:wght@400;500;600;700;800&amp;family=Space+Mono:wght@400;700&amp;display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0A0908;
    --surface:#151310;
    --surface-2:#1E1B16;
    --border:#2A251E;
    --red:#EDEDEB;
    --gold:#9A9A96;
    --accent-ink:#0A0A0A;
    --text:#EDE8DF;
    --muted:#8C857A;
    --radius:14px;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:'Manrope',sans-serif;
    line-height:1.5;
    -webkit-font-smoothing:antialiased;
  }
  @media (prefers-reduced-motion: reduce){
    html{scroll-behavior:auto;}
    *{animation-duration:0.01ms !important; transition-duration:0.01ms !important;}
  }
  a{color:inherit;text-decoration:none;}
  button{font-family:inherit;cursor:pointer;}
  :focus-visible{outline:2px solid var(--gold); outline-offset:2px;}

  .gota{display:inline-block;width:.5em;height:.7em;background:var(--red);
    border-radius:0 55% 55% 55%;transform:rotate(45deg);vertical-align:middle;}

  header{
    position:sticky;top:0;z-index:50;
    background:rgba(10,9,8,0.88);
    backdrop-filter:blur(10px);
    border-bottom:1px solid var(--border);
  }
  .header-inner{
    max-width:1180px;margin:0 auto;padding:16px 24px;
    display:flex;align-items:center;justify-content:space-between;gap:16px;
  }
  .logo-img{height:32px;width:auto;display:block;}
  .header-right{display:flex;align-items:center;gap:10px;}
  .header-cta{
    display:flex;align-items:center;gap:8px;
    background:var(--red);color:var(--accent-ink);padding:10px 18px;
    border-radius:999px;font-weight:700;font-size:0.85rem;
    border:none;transition:transform .15s ease, background .2s ease;
  }
  .header-cta:hover{background:#c9c9c5;transform:translateY(-1px);}
  .admin-toggle{
    background:transparent;border:1px solid var(--border);color:var(--muted);
    padding:9px 14px;border-radius:999px;font-size:0.78rem;font-weight:700;
    transition:all .15s ease;
  }
  .admin-toggle:hover{border-color:var(--gold);color:var(--text);}

  .hero{
    max-width:1180px;margin:0 auto;padding:64px 24px 44px;
    display:grid;grid-template-columns:1.3fr 1fr;gap:48px;align-items:end;
  }
  .hero h1{
    font-family:'Fraunces',serif;font-weight:500;font-style:italic;
    font-size:clamp(2.2rem,5vw,3.6rem);line-height:1.08;
    letter-spacing:-0.01em;
  }
  .hero h1 span{color:var(--red);font-style:normal;}
  .hero p{color:var(--muted);max-width:420px;margin-top:18px;font-size:1.02rem;}
  .hero-note{
    font-family:'Space Mono',monospace;font-size:0.75rem;color:var(--gold);
    text-transform:uppercase;letter-spacing:0.12em;margin-bottom:14px;
  }
  .hero-meta{
    display:flex;gap:28px;font-family:'Space Mono',monospace;font-size:0.78rem;
    color:var(--muted);border-left:2px solid var(--border);padding-left:20px;
  }
  .hero-meta b{color:var(--text);display:block;font-size:1.3rem;font-family:'Fraunces',serif;font-weight:600;}

  .filters{
    max-width:1180px;margin:0 auto;padding:0 24px 28px;
    display:flex;flex-wrap:wrap;gap:10px;align-items:center;
    border-bottom:1px solid var(--border);padding-bottom:28px;
  }
  .chip{
    background:var(--surface);border:1px solid var(--border);color:var(--muted);
    padding:8px 16px;border-radius:999px;font-size:0.82rem;font-weight:600;
    transition:all .15s ease;white-space:nowrap;
  }
  .chip:hover{border-color:var(--gold);color:var(--text);}
  .chip.active{background:var(--text);color:var(--bg);border-color:var(--text);}
  .search-wrap{margin-left:auto;position:relative;min-width:220px;flex:1;max-width:280px;}
  .search-wrap input{
    width:100%;background:var(--surface);border:1px solid var(--border);
    color:var(--text);padding:9px 14px;border-radius:999px;font-size:0.85rem;
  }
  .search-wrap input::placeholder{color:var(--muted);}

  .grid-wrap{max-width:1180px;margin:0 auto;padding:32px 24px 80px;}
  .count{font-family:'Space Mono',monospace;font-size:0.75rem;color:var(--muted);
    text-transform:uppercase;letter-spacing:0.1em;margin-bottom:20px;}
  .grid{
    display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:22px;
  }
  .card{
    background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
    padding:20px;display:flex;flex-direction:column;gap:14px;
    transition:transform .2s ease, border-color .2s ease;
  }
  .card:hover{transform:translateY(-4px);border-color:var(--gold);}
  .card-media{
    position:relative;width:100%;height:200px;border-radius:10px;overflow:hidden;
    background:var(--bg);display:flex;align-items:center;justify-content:center;
  }
  .card-media img{width:100%;height:100%;object-fit:contain;display:block;padding:10px;box-sizing:border-box;}
  .card-media .bottle{width:auto;height:78%;}
  .fam-tag{
    position:absolute;top:10px;left:10px;
    background:rgba(10,10,10,0.72);backdrop-filter:blur(4px);
    font-family:'Space Mono',monospace;font-size:0.65rem;text-transform:uppercase;
    letter-spacing:0.08em;padding:4px 9px;border-radius:6px;
    display:inline-flex;align-items:center;gap:6px;color:var(--muted);
    border:1px solid var(--border);
  }
  .fam-dot{width:7px;height:7px;border-radius:50%;}
  .card h3{font-family:'Fraunces',serif;font-size:1.2rem;font-weight:600;}
  .card .gender{color:var(--muted);font-size:0.78rem;}
  .card p.desc{color:var(--muted);font-size:0.85rem;}
  .pyramid{display:flex;flex-direction:column;gap:6px;margin-top:2px;}
  .pyramid-row{display:flex;gap:8px;align-items:baseline;}
  .pyramid-label{
    font-family:'Space Mono',monospace;font-size:0.62rem;color:var(--gold);
    text-transform:uppercase;letter-spacing:0.06em;width:52px;flex-shrink:0;
  }
  .pyramid-notes{font-size:0.78rem;color:var(--text);opacity:0.85;}
  .card-bottom{
    display:flex;justify-content:space-between;align-items:center;
    border-top:1px solid var(--border);padding-top:14px;margin-top:auto;
  }
  .price{font-family:'Fraunces',serif;font-size:1.15rem;font-weight:600;}
  .price small{font-family:'Manrope',sans-serif;color:var(--muted);font-size:0.72rem;font-weight:500;}
  .wa-btn{
    display:flex;align-items:center;gap:6px;background:var(--surface-2);
    border:1px solid var(--border);color:var(--text);padding:9px 14px;
    border-radius:999px;font-size:0.78rem;font-weight:700;
    transition:background .2s ease, border-color .2s ease;
  }
  .wa-btn:hover{background:var(--red);border-color:var(--red);color:var(--accent-ink);}
  .no-results{color:var(--muted);text-align:center;padding:60px 0;font-family:'Space Mono',monospace;font-size:0.85rem;}

  .float-wa{
    position:fixed;bottom:22px;right:22px;z-index:60;
    background:var(--red);color:var(--accent-ink);width:56px;height:56px;border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 8px 24px rgba(0,0,0,0.5);
    transition:transform .2s ease;
  }
  .float-wa:hover{transform:scale(1.08);}

  footer{border-top:1px solid var(--border);padding:36px 24px;text-align:center;
    color:var(--muted);font-size:0.8rem;}
  footer .logo-img{height:20px;margin:0 auto 10px;opacity:0.7;}

  /* ---------- admin panel ---------- */
  .admin-overlay{
    position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:99;
    display:none;
  }
  .admin-overlay.open{display:block;}
  .admin-panel{
    position:fixed;top:0;right:0;bottom:0;width:min(420px,100%);
    background:var(--surface);border-left:1px solid var(--border);
    z-index:100;transform:translateX(100%);transition:transform .25s ease;
    overflow-y:auto;padding:24px;
  }
  .admin-panel.open{transform:translateX(0);}
  .admin-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;}
  .admin-header h2{font-family:'Fraunces',serif;font-size:1.3rem;}
  .close-btn{background:var(--surface-2);border:1px solid var(--border);color:var(--text);
    width:32px;height:32px;border-radius:50%;font-size:1rem;}
  .field{margin-bottom:14px;}
  .field label{display:block;font-size:0.75rem;color:var(--muted);margin-bottom:5px;
    font-family:'Space Mono',monospace;text-transform:uppercase;letter-spacing:0.05em;}
  .field input, .field select, .field textarea{
    width:100%;background:var(--surface-2);border:1px solid var(--border);color:var(--text);
    padding:9px 12px;border-radius:8px;font-size:0.88rem;font-family:'Manrope',sans-serif;
  }
  .field-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
  .img-preview{width:100%;height:120px;object-fit:cover;border-radius:8px;margin-top:8px;
    border:1px solid var(--border);display:none;}
  .btn-primary{
    width:100%;background:var(--red);color:var(--accent-ink);border:none;padding:12px;
    border-radius:8px;font-weight:700;font-size:0.9rem;margin-top:6px;
  }
  .btn-primary:hover{background:#c9c9c5;}
  .btn-secondary{
    width:100%;background:var(--surface-2);color:var(--text);border:1px solid var(--border);
    padding:11px;border-radius:8px;font-weight:700;font-size:0.85rem;margin-top:8px;
  }
  .btn-secondary:hover{border-color:var(--gold);}
  .admin-divider{border-top:1px solid var(--border);margin:22px 0;padding-top:20px;}
  .admin-list-item{
    display:flex;align-items:center;gap:10px;padding:10px;background:var(--surface-2);
    border-radius:8px;margin-bottom:8px;
  }
  .admin-list-item img, .admin-list-item .thumb-fallback{
    width:36px;height:36px;border-radius:6px;object-fit:cover;flex-shrink:0;background:var(--border);
  }
  .admin-list-item .info{flex-grow:1;min-width:0;}
  .admin-list-item .info b{display:block;font-size:0.85rem;}
  .admin-list-item .info span{font-size:0.72rem;color:var(--muted);}
  .admin-list-item .actions{display:flex;gap:6px;}
  .admin-list-item button{
    background:transparent;border:1px solid var(--border);color:var(--muted);
    width:28px;height:28px;border-radius:6px;font-size:0.8rem;
  }
  .admin-list-item button:hover{border-color:var(--gold);color:var(--text);}
  .admin-note{font-size:0.78rem;color:var(--muted);line-height:1.5;margin-bottom:14px;
    background:var(--surface-2);padding:12px;border-radius:8px;border:1px solid var(--border);}

  @media (max-width:760px){
    .hero{grid-template-columns:1fr;gap:24px;}
    .hero-meta{border-left:none;padding-left:0;padding-top:16px;border-top:1px solid var(--border);}
    .search-wrap{max-width:100%;order:10;}
    .field-row{grid-template-columns:1fr;}
  }
</style>
<style type="text/css"></style><style>.vue-notification-group{display:block;position:fixed;z-index:5000}.vue-notification-wrapper{display:block;overflow:hidden;width:100%;margin:0;padding:0}.notification-title{font-weight:600}.vue-notification-template{display:block;box-sizing:border-box;background:#fff;text-align:left}.vue-notification{display:block;box-sizing:border-box;text-align:left;font-size:12px;padding:10px;margin:0 5px 5px;color:#fff;background:#44a4fc;border-left:5px solid #187FE7}.vue-notification.warn{background:#ffb648;border-left-color:#f48a06}.vue-notification.error{background:#e54d42;border-left-color:#b82e24}.vue-notification.success{background:#68cd86;border-left-color:#42a85f}.vn-fade-enter-active,.vn-fade-leave-active,.vn-fade-move{transition:all .5s}.vn-fade-enter-from,.vn-fade-leave-to{opacity:0}</style><style>.vue-notification-group{display:block;position:fixed;z-index:5000}.vue-notification-wrapper{display:block;overflow:hidden;width:100%;margin:0;padding:0}.notification-title{font-weight:600}.vue-notification-template{display:block;box-sizing:border-box;background:#fff;text-align:left}.vue-notification{display:block;box-sizing:border-box;text-align:left;font-size:12px;padding:10px;margin:0 5px 5px;color:#fff;background:#44a4fc;border-left:5px solid #187FE7}.vue-notification.warn{background:#ffb648;border-left-color:#f48a06}.vue-notification.error{background:#e54d42;border-left-color:#b82e24}.vue-notification.success{background:#68cd86;border-left-color:#42a85f}.vn-fade-enter-active,.vn-fade-leave-active,.vn-fade-move{transition:all .5s}.vn-fade-enter-from,.vn-fade-leave-to{opacity:0}</style><style>.vue-notification-group{display:block;position:fixed;z-index:5000}.vue-notification-wrapper{display:block;overflow:hidden;width:100%;margin:0;padding:0}.notification-title{font-weight:600}.vue-notification-template{display:block;box-sizing:border-box;background:#fff;text-align:left}.vue-notification{display:block;box-sizing:border-box;text-align:left;font-size:12px;padding:10px;margin:0 5px 5px;color:#fff;background:#44a4fc;border-left:5px solid #187FE7}.vue-notification.warn{background:#ffb648;border-left-color:#f48a06}.vue-notification.error{background:#e54d42;border-left-color:#b82e24}.vue-notification.success{background:#68cd86;border-left-color:#42a85f}.vn-fade-enter-active,.vn-fade-leave-active,.vn-fade-move{transition:all .5s}.vn-fade-enter-from,.vn-fade-leave-to{opacity:0}</style><link type="text/css" rel="stylesheet" href="//fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap"><link type="text/css" rel="stylesheet" href="//fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap"><style type="text/css"></style><style>.vue-notification-group{display:block;position:fixed;z-index:5000}.vue-notification-wrapper{display:block;overflow:hidden;width:100%;margin:0;padding:0}.notification-title{font-weight:600}.vue-notification-template{display:block;box-sizing:border-box;background:#fff;text-align:left}.vue-notification{display:block;box-sizing:border-box;text-align:left;font-size:12px;padding:10px;margin:0 5px 5px;color:#fff;background:#44a4fc;border-left:5px solid #187FE7}.vue-notification.warn{background:#ffb648;border-left-color:#f48a06}.vue-notification.error{background:#e54d42;border-left-color:#b82e24}.vue-notification.success{background:#68cd86;border-left-color:#42a85f}.vn-fade-enter-active,.vn-fade-leave-active,.vn-fade-move{transition:all .5s}.vn-fade-enter-from,.vn-fade-leave-to{opacity:0}</style><style>.vue-notification-group{display:block;position:fixed;z-index:5000}.vue-notification-wrapper{display:block;overflow:hidden;width:100%;margin:0;padding:0}.notification-title{font-weight:600}.vue-notification-template{display:block;box-sizing:border-box;background:#fff;text-align:left}.vue-notification{display:block;box-sizing:border-box;text-align:left;font-size:12px;padding:10px;margin:0 5px 5px;color:#fff;background:#44a4fc;border-left:5px solid #187FE7}.vue-notification.warn{background:#ffb648;border-left-color:#f48a06}.vue-notification.error{background:#e54d42;border-left-color:#b82e24}.vue-notification.success{background:#68cd86;border-left-color:#42a85f}.vn-fade-enter-active,.vn-fade-leave-active,.vn-fade-move{transition:all .5s}.vn-fade-enter-from,.vn-fade-leave-to{opacity:0}</style><style type="text/css"></style><style>.vue-notification-group{display:block;position:fixed;z-index:5000}.vue-notification-wrapper{display:block;overflow:hidden;width:100%;margin:0;padding:0}.notification-title{font-weight:600}.vue-notification-template{display:block;box-sizing:border-box;background:#fff;text-align:left}.vue-notification{display:block;box-sizing:border-box;text-align:left;font-size:12px;padding:10px;margin:0 5px 5px;color:#fff;background:#44a4fc;border-left:5px solid #187FE7}.vue-notification.warn{background:#ffb648;border-left-color:#f48a06}.vue-notification.error{background:#e54d42;border-left-color:#b82e24}.vue-notification.success{background:#68cd86;border-left-color:#42a85f}.vn-fade-enter-active,.vn-fade-leave-active,.vn-fade-move{transition:all .5s}.vn-fade-enter-from,.vn-fade-leave-to{opacity:0}</style><style>.vue-notification-group{display:block;position:fixed;z-index:5000}.vue-notification-wrapper{display:block;overflow:hidden;width:100%;margin:0;padding:0}.notification-title{font-weight:600}.vue-notification-template{display:block;box-sizing:border-box;background:#fff;text-align:left}.vue-notification{display:block;box-sizing:border-box;text-align:left;font-size:12px;padding:10px;margin:0 5px 5px;color:#fff;background:#44a4fc;border-left:5px solid #187FE7}.vue-notification.warn{background:#ffb648;border-left-color:#f48a06}.vue-notification.error{background:#e54d42;border-left-color:#b82e24}.vue-notification.success{background:#68cd86;border-left-color:#42a85f}.vn-fade-enter-active,.vn-fade-leave-active,.vn-fade-move{transition:all .5s}.vn-fade-enter-from,.vn-fade-leave-to{opacity:0}</style></head>
<body>

<header>
  <div class="header-inner">
    <img class="logo-img" src="data:image/png;base64," alt="Fraganz">
    <div class="header-right">
      <button class="admin-toggle" id="adminToggle">Editar catálogo</button>
      <a class="header-cta" id="headerWa" href="https://wa.me/5583993744321?text=Ol%C3%A1!%20Vim%20pelo%20cat%C3%A1logo%20da%20Fraganz%20e%20quero%20saber%20mais%20sobre%20os%20perfumes." target="_blank" rel="noopener">Falar no WhatsApp</a>
    </div>
  </div>
</header>

<section class="hero">
  <div>
    <div class="hero-note">Perfumaria importada</div>
    <h1>Elegância que <span>se sente</span><br>antes de ser vista.</h1>
    <p>Catálogo com perfumes importados selecionados. Escolha pela família olfativa, veja a pirâmide de notas e feche o pedido direto no WhatsApp.</p>
  </div>
  <div class="hero-meta">
    <div><b id="metaCount">3</b>fragrâncias</div>
    <div><b>100%</b>importado</div>
    <div><b>DDD 83</b>envio p/ todo BR</div>
  </div>
</section>

<div class="filters" id="filters"><button class="chip active" data-family="Todos">Todos</button><button class="chip " data-family="Amadeirado">Amadeirado</button><button class="chip " data-family="Oriental">Oriental</button><div class="search-wrap"><input type="text" id="searchInput" placeholder="Buscar por nome..."></div></div>

<div class="grid-wrap">
  <div class="count" id="resultCount">3 fragrâncias encontradas</div>
  <div class="grid" id="grid">
      <div class="card">
        <div class="card-media">
          <img class="bottle" src="data:image/png;base64," alt="Club de Nuit intense man">
          <span class="fam-tag"><span class="fam-dot" style="background:#6E6E6A"></span>Amadeirado</span>
        </div>
        <div>
          <h3>Club de Nuit intense man</h3>
          <div class="gender">Masculino · 105ml</div>
        </div>
        <p class="desc">Fragrância intensa, sofisticada e marcante, perfeita para noites e ocasiões especiais.</p>
        <div class="pyramid">
          <div class="pyramid-row"><span class="pyramid-label">Topo</span><span class="pyramid-notes">Limão, Abacaxi, Bergamota, Groselha Preta, Maçã</span></div>
          <div class="pyramid-row"><span class="pyramid-label">Coração</span><span class="pyramid-notes">Bétula, Jasmim, Rosa</span></div>
          <div class="pyramid-row"><span class="pyramid-label">Fundo</span><span class="pyramid-notes">Âmbar, Almíscar, Baunilha, Patchouli</span></div>
        </div>
        <div class="card-bottom">
          <div class="price">R$ 249,90<br><small>105ml</small></div>
          <a class="wa-btn" href="https://wa.me/5583993744321?text=Ol%C3%A1!%20Vim%20pelo%20cat%C3%A1logo%20da%20Fraganz%20e%20quero%20saber%20mais%20sobre%20o%20perfume%20Club%20de%20Nuit%20intense%20man%20(105ml)." target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.94 7.94 0 0 0-6.9 11.9L4 20l4.2-1.1a7.9 7.9 0 0 0 3.85 1h.01A7.94 7.94 0 0 0 20 11.94a7.9 7.9 0 0 0-2.4-5.62z"></path></svg>
            Falar
          </a>
        </div>
      </div>
      <div class="card">
        <div class="card-media">
          <img class="bottle" src="data:image/png;base64," alt="Lattafa Asad Eau de Parfum">
          <span class="fam-tag"><span class="fam-dot" style="background:#4A4A47"></span>Oriental</span>
        </div>
        <div>
          <h3>Lattafa Asad Eau de Parfum</h3>
          <div class="gender">Masculino · 100ml</div>
        </div>
        <p class="desc">Quente, intenso e sofisticado, ideal para noites e clima ameno.</p>
        <div class="pyramid">
          <div class="pyramid-row"><span class="pyramid-label">Topo</span><span class="pyramid-notes">Pimenta Preta, Abacaxi, Tabaco</span></div>
          <div class="pyramid-row"><span class="pyramid-label">Coração</span><span class="pyramid-notes">Café, Íris, Patchouli</span></div>
          <div class="pyramid-row"><span class="pyramid-label">Fundo</span><span class="pyramid-notes">Baunilha, Âmbar, Madeira Seca, Benjoim, Ládano</span></div>
        </div>
        <div class="card-bottom">
          <div class="price">R$ 239,90<br><small>100ml</small></div>
