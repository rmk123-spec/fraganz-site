<script>
/* ==========================================================================
   WHATSAPP — edite seu número aqui (formato: código do país + DDD + número)
   ========================================================================== */
const WHATSAPP_NUMBER = "5583993744321";

/* ==========================================================================
   ACESSO AO PAINEL DE EDIÇÃO
   - ADMIN_KEY: acrescente ?admin=SUACHAVE na URL pra fazer o botão aparecer.
     Ex: https://seusite.netlify.app/?admin=fraganz2026
   - ADMIN_PASSWORD: senha pedida ao clicar em "Editar catálogo".
   ========================================================================== */
const ADMIN_KEY = "fraganz2026";
const ADMIN_PASSWORD = "rmkfodeboladin123";

/* PRODUCTS_START */
const PRODUCTS_SEED = [
  {
    "name": "Club de Nuit intense man",
    "family": "Amadeirado",
    "gender": "Masculino",
    "ml": 105,
    "price": 249.9,
    "desc": "Fragrância intensa, sofisticada e marcante, perfeita para noites e ocasiões especiais.",
    "image": "data:image/png;base64,",
    "notes": {
      "top": [
        "Limão",
        "Abacaxi",
        "Bergamota",
        "Groselha Preta",
        "Maçã"
      ],
      "heart": [
        "Bétula",
        "Jasmim",
        "Rosa"
      ],
      "base": [
        "Âmbar",
        "Almíscar",
        "Baunilha",
        "Patchouli"
      ]
    },
    "id": "p1783320149745"
  },
  {
    "name": "Lattafa Asad Eau de Parfum",
    "family": "Oriental",
    "gender": "Masculino",
    "ml": 100,
    "price": 239.9,
    "desc": "Quente, intenso e sofisticado, ideal para noites e clima ameno.",
    "image": "data:image/png;base64,",
    "notes": {
      "top": [
        "Pimenta Preta",
        "Abacaxi",
        "Tabaco"
      ],
      "heart": [
        "Café",
        "Íris",
        "Patchouli"
      ],
      "base": [
        "Baunilha",
        "Âmbar",
        "Madeira Seca",
        "Benjoim",
        "Ládano"
      ]
    },
    "id": "p1783322611615"
  },
  {
    "name": "Lattafa Yara Eau de Parfum",
    "family": "Oriental",
    "gender": "Feminino",
    "ml": 100,
    "price": 219.9,
    "desc": "Doce, cremoso e delicado, perfeito para o dia a dia e ocasiões especiais.",
    "image": "data:image/png;base64,",
    "notes": {
      "top": [
        "Orquídea",
        "Heliotrópio",
        "Tangerina"
      ],
      "heart": [
        "Acorde Gourmand",
        "Frutas Tropicais"
      ],
      "base": [
        "Baunilha",
        "Almíscar",
        "Sândalo"
      ]
    },
    "id": "p1783322911126"
  }
];
/* PRODUCTS_END */

const FAMILY_COLORS = {
  "Amadeirado":"#6E6E6A", "Floral":"#B8B8B4", "Cítrico":"#8C8C88",
  "Oriental":"#4A4A47", "Aromático":"#D6D6D2"
};

let PRODUCTS = [];
let activeFamily = "Todos";
let searchTerm = "";
let editingId = null;

function loadProducts(){
  const draft = localStorage.getItem('fraganz_draft');
  PRODUCTS = draft ? JSON.parse(draft) : JSON.parse(JSON.stringify(PRODUCTS_SEED));
}
function saveDraft(){
  localStorage.setItem('fraganz_draft', JSON.stringify(PRODUCTS));
}

function waLink(text){
  return `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(text)}`;
}

function bottleSVG(color){
  return `<svg class="bottle" viewBox="0 0 56 72" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="22" y="4" width="12" height="10" rx="2" fill="${color}" opacity="0.9"/>
    <rect x="24" y="0" width="8" height="6" rx="1.5" fill="${color}"/>
    <path d="M14 20 C14 15 18 14 28 14 C38 14 42 15 42 20 L44 66 C44 69 41 71 38 71 L18 71 C15 71 12 69 12 66 Z"
      fill="#1E1B16" stroke="${color}" stroke-width="1.5"/>
    <path d="M16 30 L40 30 L42 66 C42 68 40 70 38 70 L18 70 C16 70 14 68 14 66 Z" fill="${color}" opacity="0.18"/>
  </svg>`;
}

function getFamilies(){
  return ["Todos", ...new Set(PRODUCTS.map(p=>p.family))];
}

function renderFilters(){
  const wrap = document.getElementById('filters');
  wrap.innerHTML = getFamilies().map(f =>
    `<button class="chip ${f===activeFamily?'active':''}" data-family="${f}">${f}</button>`
  ).join('') + `<div class="search-wrap"><input type="text" id="searchInput" placeholder="Buscar por nome..."></div>`;

  wrap.querySelectorAll('.chip').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      activeFamily = btn.dataset.family;
      renderFilters();
      renderGrid();
    });
  });
  document.getElementById('searchInput').value = searchTerm;
  document.getElementById('searchInput').addEventListener('input', (e)=>{
    searchTerm = e.target.value;
    renderGrid();
  });
}

function renderGrid(){
  const grid = document.getElementById('grid');
  const filtered = PRODUCTS.filter(p=>{
    const matchFamily = activeFamily==="Todos" || p.family===activeFamily;
    const matchSearch = p.name.toLowerCase().includes(searchTerm.toLowerCase());
    return matchFamily && matchSearch;
  });

  document.getElementById('resultCount').textContent = `${filtered.length} fragrância${filtered.length===1?'':'s'} encontrada${filtered.length===1?'':'s'}`;
  document.getElementById('metaCount').textContent = PRODUCTS.length;

  if(filtered.length===0){
    grid.innerHTML = `<div class="no-results">Nenhum perfume encontrado com esse filtro.</div>`;
    return;
  }

  grid.innerHTML = filtered.map(p=>{
    const color = FAMILY_COLORS[p.family] || "#8C857A";
    const msg = `Olá! Vim pelo catálogo da Fraganz e quero saber mais sobre o perfume ${p.name} (${p.ml}ml).`;
    const media = p.image
      ? `<img class="bottle" src="${p.image}" alt="${p.name}">`
      : bottleSVG(color);
    return `
      <div class="card">
        <div class="card-media">
          ${media}
          <span class="fam-tag"><span class="fam-dot" style="background:${color}"></span>${p.family}</span>
        </div>
        <div>
          <h3>${p.name}</h3>
          <div class="gender">${p.gender} · ${p.ml}ml</div>
        </div>
        <p class="desc">${p.desc}</p>
        <div class="pyramid">
          <div class="pyramid-row"><span class="pyramid-label">Topo</span><span class="pyramid-notes">${p.notes.top.join(', ')}</span></div>
          <div class="pyramid-row"><span class="pyramid-label">Coração</span><span class="pyramid-notes">${p.notes.heart.join(', ')}</span></div>
          <div class="pyramid-row"><span class="pyramid-label">Fundo</span><span class="pyramid-notes">${p.notes.base.join(', ')}</span></div>
        </div>
        <div class="card-bottom">
          <div class="price">R$ ${p.price.toFixed(2).replace('.',',')}<br><small>${p.ml}ml</small></div>
          <a class="wa-btn" href="${waLink(msg)}" target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.94 7.94 0 0 0-6.9 11.9L4 20l4.2-1.1a7.9 7.9 0 0 0 3.85 1h.01A7.94 7.94 0 0 0 20 11.94a7.9 7.9 0 0 0-2.4-5.62z"/></svg>
            Falar
          </a>
        </div>
      </div>`;
  }).join('');
}

/* ---------- admin panel logic ---------- */
function renderAdminList(){
  const list = document.getElementById('adminList');
  document.getElementById('adminCount').textContent = PRODUCTS.length;
  list.innerHTML = PRODUCTS.map(p=>{
    const thumb = p.image ? `<img src="${p.image}">` : `<div class="thumb-fallback"></div>`;
    return `
      <div class="admin-list-item">
        ${thumb}
        <div class="info"><b>${p.name}</b><span>${p.family} · R$ ${p.price.toFixed(2).replace('.',',')}</span></div>
        <div class="actions">
          <button data-edit="${p.id}" title="Editar">✎</button>
          <button data-remove="${p.id}" title="Remover">🗑</button>
        </div>
      </div>`;
  }).join('');

  list.querySelectorAll('[data-edit]').forEach(btn=>{
    btn.addEventListener('click', ()=> startEdit(btn.dataset.edit));
  });
  list.querySelectorAll('[data-remove]').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      if(confirm('Remover este produto?')){
        PRODUCTS = PRODUCTS.filter(p=>p.id!==btn.dataset.remove);
        saveDraft(); renderAdminList(); renderFilters(); renderGrid();
      }
    });
  });
}

function clearForm(){
  document.getElementById('fImage').value='';
  document.getElementById('imgPreview').style.display='none';
  document.getElementById('imgPreview').src='';
  document.getElementById('fName').value='';
  document.getElementById('fFamily').value='Amadeirado';
  document.getElementById('fGender').value='Masculino';
  document.getElementById('fMl').value='';
  document.getElementById('fPrice').value='';
  document.getElementById('fDesc').value='';
  document.getElementById('fTop').value='';
  document.getElementById('fHeart').value='';
  document.getElementById('fBase').value='';
  editingId = null;
  document.getElementById('formTitle').textContent = 'Adicionar produto';
  document.getElementById('saveProduct').textContent = 'Adicionar produto';
  document.getElementById('cancelEdit').style.display = 'none';
}

function startEdit(id){
  const p = PRODUCTS.find(x=>x.id===id);
  if(!p) return;
  editingId = id;
  document.getElementById('fName').value = p.name;
  document.getElementById('fFamily').value = p.family;
  document.getElementById('fGender').value = p.gender;
  document.getElementById('fMl').value = p.ml;
  document.getElementById('fPrice').value = p.price;
  document.getElementById('fDesc').value = p.desc;
  document.getElementById('fTop').value = p.notes.top.join(', ');
  document.getElementById('fHeart').value = p.notes.heart.join(', ');
  document.getElementById('fBase').value = p.notes.base.join(', ');
  if(p.image){
    document.getElementById('imgPreview').src = p.image;
    document.getElementById('imgPreview').style.display='block';
  } else {
    document.getElementById('imgPreview').style.display='none';
  }
  document.getElementById('formTitle').textContent = 'Editar produto';
  document.getElementById('saveProduct').textContent = 'Salvar alterações';
  document.getElementById('cancelEdit').style.display = 'block';
  document.getElementById('adminPanel').scrollTop = 0;
}

function resizeImage(file, maxW){
  return new Promise((resolve)=>{
    const isPng = file.type === 'image/png';
    const reader = new FileReader();
    reader.onload = (e)=>{
      const img = new Image();
      img.onload = ()=>{
        const scale = Math.min(1, maxW / img.width);
        const canvas = document.createElement('canvas');
        canvas.width = img.width * scale;
        canvas.height = img.height * scale;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
        // PNG mantém transparência; JPEG é usado só pra fotos sem fundo transparente (arquivo menor)
        resolve(isPng ? canvas.toDataURL('image/png') : canvas.toDataURL('image/jpeg', 0.85));
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  });
}

document.getElementById('fImage').addEventListener('change', async (e)=>{
  const file = e.target.files[0];
  if(!file) return;
  const dataUrl = await resizeImage(file, 500);
  document.getElementById('imgPreview').src = dataUrl;
  document.getElementById('imgPreview').style.display = 'block';
  document.getElementById('imgPreview').dataset.pending = dataUrl;
});

document.getElementById('saveProduct').addEventListener('click', ()=>{
  const name = document.getElementById('fName').value.trim();
  if(!name){ alert('Digite o nome do produto.'); return; }
  const preview = document.getElementById('imgPreview');
  const image = preview.style.display==='block' ? preview.src : null;

  const data = {
    name,
    family: document.getElementById('fFamily').value,
    gender: document.getElementById('fGender').value,
    ml: Number(document.getElementById('fMl').value) || 0,
    price: Number(document.getElementById('fPrice').value) || 0,
    desc: document.getElementById('fDesc').value.trim(),
    image,
    notes:{
      top: document.getElementById('fTop').value.split(',').map(s=>s.trim()).filter(Boolean),
      heart: document.getElementById('fHeart').value.split(',').map(s=>s.trim()).filter(Boolean),
      base: document.getElementById('fBase').value.split(',').map(s=>s.trim()).filter(Boolean),
    }
  };

  if(editingId){
    const idx = PRODUCTS.findIndex(p=>p.id===editingId);
    PRODUCTS[idx] = {...PRODUCTS[idx], ...data};
  } else {
    data.id = 'p' + Date.now();
    PRODUCTS.push(data);
  }
  saveDraft();
  renderAdminList(); renderFilters(); renderGrid();
  clearForm();
});

document.getElementById('cancelEdit').addEventListener('click', clearForm);

document.getElementById('resetDraft').addEventListener('click', ()=>{
  if(confirm('Isso vai apagar suas edições e voltar ao catálogo original. Continuar?')){
    localStorage.removeItem('fraganz_draft');
    loadProducts();
    renderAdminList(); renderFilters(); renderGrid();
    clearForm();
  }
});

document.getElementById('downloadFile').addEventListener('click', ()=>{
  const newArrayText = 'const PRODUCTS_SEED = ' + JSON.stringify(PRODUCTS, null, 2) + ';';

  // Clona o documento pra não salvar o estado "destravado" da tela atual
  // (botão visível, painel aberto etc.) junto com o arquivo.
  const clone = document.documentElement.cloneNode(true);
  const clonedToggle = clone.querySelector('#adminToggle');
  if(clonedToggle) clonedToggle.removeAttribute('style');
  const clonedPanel = clone.querySelector('#adminPanel');
  if(clonedPanel) clonedPanel.classList.remove('open');
  const clonedOverlay = clone.querySelector('#adminOverlay');
  if(clonedOverlay) clonedOverlay.classList.remove('open');

  let source = '<!DOCTYPE html>\n' + clone.outerHTML;
  source = source.replace(
    /\/\* PRODUCTS_START \*\/[\s\S]*?\/\* PRODUCTS_END \*\//,
    '/* PRODUCTS_START */\n' + newArrayText + '\n/* PRODUCTS_END */'
  );
  const blob = new Blob([source], {type:'text/html'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'fraganz-catalogo.html';
  a.click();
  URL.revokeObjectURL(url);
});

function checkAdminAccess(){
  const params = new URLSearchParams(window.location.search);
  if(params.get('admin') === ADMIN_KEY){
    document.getElementById('adminToggle').style.display = 'inline-flex';
  }
}

document.getElementById('adminToggle').addEventListener('click', ()=>{
  const alreadyUnlocked = sessionStorage.getItem('fraganz_admin_ok') === '1';
  if(!alreadyUnlocked){
    const attempt = prompt('Senha do painel de edição:');
    if(attempt !== ADMIN_PASSWORD){
      if(attempt !== null) alert('Senha incorreta.');
      return;
    }
    sessionStorage.setItem('fraganz_admin_ok', '1');
  }
  document.getElementById('adminPanel').classList.add('open');
  document.getElementById('adminOverlay').classList.add('open');
});
checkAdminAccess();
function closeAdminPanel(){
  document.getElementById('adminPanel').classList.remove('open');
  document.getElementById('adminOverlay').classList.remove('open');
  clearForm();
}
document.getElementById('closeAdmin').addEventListener('click', closeAdminPanel);
document.getElementById('adminOverlay').addEventListener('click', closeAdminPanel);

document.getElementById('headerWa').href = waLink("Olá! Vim pelo catálogo da Fraganz e quero saber mais sobre os perfumes.");
document.getElementById('floatWa').href = waLink("Olá! Vim pelo catálogo da Fraganz e quero saber mais sobre os perfumes.");

loadProducts();
renderFilters();
renderGrid();
renderAdminList();
</script>



<div id="cpn-wrapper" style="display: block;"></div></body></html>
